# Copy to .env and fill in your real values.

# Required: Google Gemini API key for the LLM teacher and score-prep models.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the storage backend. Defaults to local_adls/ on disk.
# MASTERCLASS_STORAGE=local
# MASTERCLASS_STORAGE_ROOT=./local_adls

# Optional: bind address for the API.
# MASTERCLASS_HOST=127.0.0.1
# MASTERCLASS_PORT=8770

# Google Sign-In (OAuth 2.0 Authorization Code + PKCE).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8770/auth/callback

# Fernet key for encrypting per-user Gemini API keys.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTERCLASS_KEY_ENCRYPTION_KEY=

# Local dev only: allow fallback to GEMINI_API_KEY if a signed-in user has no BYO key.
ALLOW_SERVER_DEFAULT_KEY=true
